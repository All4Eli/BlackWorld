# ═══════════════════════════════════════════════════════════════════
# BLACKWORLD — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── 1. POSTGRESQL DATABASE ──
# Requirements: Must point to your Supabase/PostgreSQL connection string.
# IMPORTANT: For Vercel Serverless deployments, use the connection pooler URL (usually port 6543)
# format: postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-db-host.supabase.co:6543/postgres?sslmode=require"

# ── 2. AUTHENTICATION (CUSTOM JWT) ──
# Requirements: A cryptographically secure, random 64-character string.
# DO NOT hardcode this in any file.
# You can generate one via: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_SECURE_64_CHAR_HEX_STRING_HERE"

# ── 3. SUPABASE REALTIME (CHAT & PRESENCE) ──
# These must be prefixed with NEXT_PUBLIC_ so the client frontend can attach to WebSockets.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ...your_anon_key_here..."
